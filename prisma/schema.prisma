// EstateCall - Prisma schema
// Real Estate Multi AI Agent Platform: listings, AI calling agents,
// appointment booking, client portal, Stripe payments, support tickets, website builder.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ACCOUNTS
// ---------------------------------------------------------------------------

// The real-estate professional/company that owns the dashboard (agency admin)
model Agent {
  id                 String   @id @default(uuid())
  email              String   @unique
  password           String
  fullName           String
  companyName        String?
  phone              String?
  role               AgentRole @default(OWNER)
  stripeCustomerId   String?
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionPlan   String?  // e.g. "website_builder_monthly"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  properties     Property[]
  aiAgents       AIAgent[]
  appointments   Appointment[]     @relation("AssignedAgent")
  supportTickets SupportTicket[]   @relation("AgentTickets")
  website        Website?
  notifications  Notification[]

  @@map("agents")
}

enum AgentRole {
  OWNER
  TEAM_MEMBER
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

// The lead / customer who books viewings through the AI agent or website
model Client {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String?  // null until the client creates a portal account
  fullName     String
  phone        String?
  budgetRange  String?
  financing    FinancingStatus?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments   Appointment[]
  supportTickets SupportTicket[] @relation("ClientTickets")

  @@map("clients")
}

enum FinancingStatus {
  PRE_APPROVED
  PLANNING_UPFRONT
  NEEDS_FINANCING
  NOT_SPECIFIED
}

// ---------------------------------------------------------------------------
// PROPERTIES
// ---------------------------------------------------------------------------

model Property {
  id                String   @id @default(uuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  title             String
  description       String?
  propertyType      PropertyType   @default(RESIDENTIAL)
  listingType       ListingType    @default(SALE)
  status            PropertyStatus @default(AVAILABLE)

  price             Decimal  @db.Decimal(12, 2)
  priceType         PriceType @default(FIXED)

  bedrooms          Int      @default(0)
  bathrooms         Int      @default(0)
  areaSqft          Decimal? @db.Decimal(10, 2)
  parkingSpaces     Int      @default(0)
  yearBuilt         Int?

  addressLine       String
  city              String?
  region            String?
  postalCode        String?
  country           String?
  latitude          Decimal? @db.Decimal(9, 6)
  longitude         Decimal? @db.Decimal(9, 6)

  amenities         String[] @default([])
  images            String[] @default([])

  visibleToAiAgent  Boolean  @default(true)
  featured          Boolean  @default(false)
  active            Boolean  @default(true)

  aiAgentId         String?
  aiAgent           AIAgent? @relation(fields: [aiAgentId], references: [id])

  appointments      Appointment[]
  callLogs          CallLog[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([listingType])
  @@map("properties")
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  APARTMENT
  TOWNHOUSE
  LAND
}

enum ListingType {
  SALE
  RENT
}

enum PropertyStatus {
  AVAILABLE
  PENDING
  SOLD
  RENTED
  WITHDRAWN
}

enum PriceType {
  FIXED
  MONTHLY
}

// ---------------------------------------------------------------------------
// AI CALLING AGENTS
// ---------------------------------------------------------------------------

model AIAgent {
  id             String   @id @default(uuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name           String   // e.g. "Alexis", "Residential Specialist"
  specialty      String?  // e.g. "Residential", "Commercial"
  greetingScript String   @default("Hello, thank you for calling. I'm your AI real estate assistant. How can I help you today?")
  voiceId        String?  // provider voice id (e.g. ElevenLabs / OpenAI voice)
  personality    String?  // free-text instructions for the LLM system prompt
  active         Boolean  @default(true)

  properties     Property[]
  callLogs       CallLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("ai_agents")
}

// ---------------------------------------------------------------------------
// CALLS
// ---------------------------------------------------------------------------

model CallLog {
  id              String   @id @default(uuid())
  aiAgentId       String
  aiAgent         AIAgent  @relation(fields: [aiAgentId], references: [id])
  propertyId      String?
  property        Property? @relation(fields: [propertyId], references: [id])

  callerPhone     String?
  callerName      String?
  direction       CallDirection @default(INBOUND)
  durationSeconds Int      @default(0)
  outcome         CallOutcome @default(INFO_ONLY)
  transcript      String?  @db.Text
  recordingUrl    String?

  createdAt       DateTime @default(now())

  @@index([aiAgentId])
  @@map("call_logs")
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  INFO_ONLY
  APPOINTMENT_BOOKED
  TRANSFERRED_TO_HUMAN
  NO_ANSWER
  VOICEMAIL
}

// ---------------------------------------------------------------------------
// APPOINTMENTS
// ---------------------------------------------------------------------------

model Appointment {
  id              String   @id @default(uuid())

  propertyId      String
  property        Property @relation(fields: [propertyId], references: [id])

  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])

  assignedAgentId String?
  assignedAgent   Agent?   @relation("AssignedAgent", fields: [assignedAgentId], references: [id])

  type            AppointmentType @default(VIEWING)
  status          AppointmentStatus @default(PENDING)

  scheduledDate   DateTime
  durationMinutes Int      @default(45)
  notes           String?

  paymentStatus   PaymentStatus @default(UNPAID)
  paymentId       String?
  payment         Payment?

  rescheduleOf    String?  // previous appointment id, if this replaced one

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
  @@index([clientId])
  @@index([status])
  @@map("appointments")
}

enum AppointmentType {
  VIEWING
  CONSULTATION
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  RESCHEDULE_REQUESTED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PAY_IN_CASH
  PAID_ONLINE
}

// ---------------------------------------------------------------------------
// PAYMENTS (Stripe)
// ---------------------------------------------------------------------------

model Payment {
  id                    String   @id @default(uuid())
  appointmentId         String   @unique
  appointment           Appointment @relation(fields: [appointmentId], references: [id])

  stripePaymentIntentId String?  @unique
  amount                Decimal  @db.Decimal(12, 2)
  currency              String   @default("usd")
  status                PaymentIntentStatus @default(PENDING)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("payments")
}

enum PaymentIntentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

// ---------------------------------------------------------------------------
// SUPPORT
// ---------------------------------------------------------------------------

model SupportTicket {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation("ClientTickets", fields: [clientId], references: [id])
  agentId   String
  agent     Agent    @relation("AgentTickets", fields: [agentId], references: [id])

  subject   String
  status    TicketStatus @default(OPEN)

  messages  SupportMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_tickets")
}

enum TicketStatus {
  OPEN
  PENDING
  CLOSED
}

model SupportMessage {
  id            String   @id @default(uuid())
  ticketId      String
  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderType    SenderType
  message       String   @db.Text
  attachmentUrl String?

  createdAt     DateTime @default(now())

  @@map("support_messages")
}

enum SenderType {
  CLIENT
  AGENT
}

// ---------------------------------------------------------------------------
// WEBSITE BUILDER
// ---------------------------------------------------------------------------

model Website {
  id         String   @id @default(uuid())
  agentId    String   @unique
  agent      Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  subdomain  String   @unique
  themeColor String   @default("#16a34a")
  fontFamily String   @default("Inter")
  heroImage  String?
  heroText   String?
  aiAgentId  String?
  published  Boolean  @default(false)
  config     Json     @default("{}")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("websites")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  type      String   // e.g. "APPOINTMENT_CANCELLED", "APPOINTMENT_RESCHEDULE_REQUESTED"
  message   String
  read      Boolean  @default(false)
  metadata  Json?

  createdAt DateTime @default(now())

  @@map("notifications")
}
