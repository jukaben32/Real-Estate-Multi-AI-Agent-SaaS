# Server
PORT=4000
NODE_ENV=development
CLIENT_DASHBOARD_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:***@localhost:5432/estatecall?schema=public"

# Supabase (conexión por HTTPS via API SQL - alternativa cuando el pooler TCP no conecta)
# El backend usa un adapter de Prisma que envía el SQL a la API SQL de Supabase.
SUPABASE_ACCESS_TOKEN=sbp_xxx_tu_access_token_de_supabase
SUPABASE_PROJECT_REF=tu_project_ref

# JWT
JWT_AGENT_SECRET=change_this_agent_secret
JWT_CLIENT_SECRET=change_this_client_secret
JWT_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_WEBSITE_PRICE_ID=price_xxx

# Email (SMTP - e.g. Resend, SendGrid SMTP, Gmail App Password, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=changeme
EMAIL_FROM="EstateCall <no-reply@estatecall.com>"
